# Copy to `.env` and adjust as needed. docker-compose reads this automatically.

# ---- Image tags ----------------------------------------------------------
DEBIAN_TAG=stable-slim
MYSQL_TAG=8
NGINX_TAG=alpine

# ---- Networks (must match the SANs/IPs baked into certs + kamailio.cfg) ---
EXTERNAL_SUBNET=172.30.10.0/24
INTERNAL_SUBNET=172.30.20.0/24

KAMAILIO_EXT_IP=172.30.10.10
KAMAILIO_INT_IP=172.30.20.10
RTPENGINE_EXT_IP=172.30.10.20
RTPENGINE_INT_IP=172.30.20.20
ASTERISK_INT_IP=172.30.20.30
MYSQL_INT_IP=172.30.20.40
WEBAPP_EXT_IP=172.30.10.50

# ---- SIP realm (must match cert SAN + seeded subscriber domain) ----------
SIP_DOMAIN=rig.local

# ---- MySQL ---------------------------------------------------------------
MYSQL_ROOT_PASSWORD=rigrootpw
MYSQL_DATABASE=kamailio
MYSQL_USER=kamailio
MYSQL_PASSWORD=kamailiopw

# ---- Sipfront agents (only needed when running agents locally) -----------
# In CI these come from repo secrets, not this file.
SF_POOL_ID=
SF_POOL_SECRET=
SF_IOTCORE_HOST=mqtt.dev.sipfront.net
