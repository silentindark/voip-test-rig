<!--
  Service-URI dialplan for the rig (context "public"). Kamailio routes INVITEs to
  moh / voicemail / ivr / attendant / ooo here.

  Announcements use tone_stream:// so the rig has ZERO dependency on sound-file
  packages and can never fail on a missing prompt. To use real prompts instead,
  install a freeswitch-sounds-* package in the Dockerfile and swap the playback
  data for a wav path, e.g.  data="ivr/ivr-welcome_to_freeswitch.wav".
-->
<include>
  <context name="public">

    <!-- Music on hold: a continuous pleasant two-tone loop -->
    <extension name="moh">
      <condition field="destination_number" expression="^moh$">
        <action application="answer"/>
        <action application="playback" data="tone_stream://%(2000,4000,440,480);loops=20"/>
        <action application="hangup"/>
      </condition>
    </extension>

    <!-- Voicemail: prompt beep, then a short 'recording' window (simulated) -->
    <extension name="voicemail">
      <condition field="destination_number" expression="^voicemail$">
        <action application="answer"/>
        <action application="sleep" data="300"/>
        <action application="playback" data="tone_stream://%(1000,0,640)"/>
        <action application="sleep" data="2000"/>
        <action application="hangup"/>
      </condition>
    </extension>

    <!-- IVR / auto-attendant: distinctive menu-style tones -->
    <extension name="ivr-attendant">
      <condition field="destination_number" expression="^(ivr|attendant)$">
        <action application="answer"/>
        <action application="sleep" data="300"/>
        <action application="playback" data="tone_stream://%(400,200,350,440);loops=3"/>
        <action application="sleep" data="2000"/>
        <action application="hangup"/>
      </condition>
    </extension>

    <!-- Out-of-office: a short announcement-style tone, then hang up -->
    <extension name="ooo">
      <condition field="destination_number" expression="^ooo$">
        <action application="answer"/>
        <action application="sleep" data="300"/>
        <action application="playback" data="tone_stream://%(1500,0,480,620)"/>
        <action application="hangup"/>
      </condition>
    </extension>

  </context>
</include>
