<!--
  Minimal Sofia SIP profile for the rig. Overrides the vanilla internal profile.
  - Binds to the container's internal-net IP (auto-detected as local_ip_v4 since
    FreeSWITCH only sits on the internal network).
  - auth-calls=false: trusts Kamailio on the internal net (no challenge).
  - Inbound calls land in the "public" dialplan context (see dialplan/public.xml).
-->
<profile name="internal">
  <settings>
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="rtp-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="5060"/>
    <param name="context" value="public"/>
    <param name="dialplan" value="XML"/>
    <param name="auth-calls" value="false"/>
    <param name="accept-blind-reg" value="true"/>
    <param name="tls" value="false"/>
    <param name="rtp-timer-name" value="soft"/>
    <param name="inbound-codec-prefs" value="PCMU,PCMA,opus"/>
    <param name="outbound-codec-prefs" value="PCMU,PCMA,opus"/>
    <param name="inbound-late-negotiation" value="true"/>
    <param name="inbound-codec-negotiation" value="generous"/>
    <param name="dtmf-duration" value="2000"/>
    <param name="rtp-timeout-sec" value="300"/>
    <param name="rtp-hold-timeout-sec" value="1800"/>
  </settings>
</profile>
